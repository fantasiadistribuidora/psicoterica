# No cachear los archivos que controlan la versión/PWA, para que el Service Worker
# se actualice de inmediato y la app nunca quede "atorada" en una versión vieja.
<IfModule mod_headers.c>
  <FilesMatch "(sw\.js|registerSW\.js|index\.html|version\.json|manifest\.webmanifest)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
